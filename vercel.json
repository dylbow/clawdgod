{
  "version": 2,
  "builds": [
    { "src": "api/polymarket-proxy.js", "use": "@vercel/edge" },
    { "src": "api/!(polymarket-proxy).js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/polymarket-proxy(/.*)?", "dest": "/api/polymarket-proxy.js" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
